# LETESE Production Environment Variables Template
# Copy to .env.production and fill in real values
# NEVER commit .env.production to version control

# =============================================
# Database
# =============================================
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/letese_prod
PGBOUNCER_URL=postgresql+asyncpg://USER:PASS@HOST:6432/letese_prod

# =============================================
# Redis
# =============================================
REDIS_URL=redis://HOST:6379/0

# =============================================
# Kafka
# =============================================
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092

# =============================================
# JWT Authentication (RS256)
# Generate with: bash scripts/generate_jwt_keys.sh
# =============================================
JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# AWS
# =============================================
AWS_REGION=ap-south-1
AWS_S3_BUCKET_DOCS=letese-tenant-docs-prod
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# =============================================
# AI / LLM Providers
# =============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# Payments — Razorpay
# =============================================
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# =============================================
# Notifications
# =============================================
WHATSAPP_API_KEY=...
MSG91_AUTH_KEY=...
EXOTEL_API_KEY=...
EXOTEL_API_TOKEN=...

# =============================================
# Voice — ElevenLabs
# =============================================
ELEVENLABS_API_KEY=...

# =============================================
# Monitoring / Alerts
# =============================================
PAGERDUTY_ROUTING_KEY=...

# =============================================
# Application Settings
# =============================================
DEBUG=false
ALLOWED_ORIGINS=https://letese.xyz,https://app.letese.xyz
LOG_LEVEL=INFO

# =============================================
# Court Scraper Settings
# =============================================
COURT_SCRAPER_INTERVAL_MINUTES=30
SCRAPE_PHC_ENABLED=true
SCRAPE_DELHI_HC_ENABLED=true
SCRAPE_SC_ENABLED=true
