# LETESE● Kubernetes Secrets Template
# Copy to secrets.yaml and fill in real values.
# IMPORTANT: secrets.yaml is in .gitignore — never commit real values.
#
# To create from this template:
#   cp secrets.yaml.example secrets.yaml
#   vim secrets.yaml  # fill in real values
#   kubectl apply -f secrets.yaml -n letese

apiVersion: v1
kind: Secret
metadata:
  name: letese-secrets
  namespace: letese
type: Opaque
stringData:
  # ── Database ────────────────────────────────────────────────────
  DATABASE_URL: "postgresql+asyncpg://letese_user:<PASSWORD>@postgres-svc:5432/letese_prod"
  PGBOUNCER_URL: "postgresql+asyncpg://letese_user:<PASSWORD>@pgbouncer-svc:6432/letese_prod"

  # ── Redis ──────────────────────────────────────────────────────
  REDIS_URL: "redis://redis-svc:6379/0"

  # ── Kafka ─────────────────────────────────────────────────────
  KAFKA_BOOTSTRAP_SERVERS: "kafka-svc:9092"

  # ── JWT (RS256 — load keys from files mounted via cert-manager) ─
  JWT_PUBLIC_KEY: |
    -----BEGIN PUBLIC KEY-----
    # PASTE RSA PUBLIC KEY HERE
    -----END PUBLIC KEY-----
  JWT_PRIVATE_KEY: |
    -----BEGIN RSA PRIVATE KEY-----
    # PASTE RSA PRIVATE KEY HERE
    -----END RSA PRIVATE KEY-----

  # ── AWS ────────────────────────────────────────────────────────
  AWS_REGION: "ap-south-1"
  AWS_S3_BUCKET_DOCS: "letese-tenant-docs-prod"
  AWS_ACCESS_KEY_ID: "<YOUR_AWS_ACCESS_KEY_ID>"
  AWS_SECRET_ACCESS_KEY: "<YOUR_AWS_SECRET_ACCESS_KEY>"

  # ── Third-party APIs ───────────────────────────────────────────
  OPENAI_API_KEY: "<YOUR_OPENAI_API_KEY>"
  ANTHROPIC_API_KEY: "<YOUR_ANTHROPIC_API_KEY>"
  RAZORPAY_KEY_ID: "<YOUR_RAZORPAY_KEY_ID>"
  RAZORPAY_KEY_SECRET: "<YOUR_RAZORPAY_KEY_SECRET>"
  WHATSAPP_API_KEY: "<YOUR_WHATSAPP_API_KEY>"
  MSG91_AUTH_KEY: "<YOUR_MSG91_AUTH_KEY>"
  EXOTEL_API_KEY: "<YOUR_EXOTEL_API_KEY>"
  EXOTEL_API_TOKEN: "<YOUR_EXOTEL_API_TOKEN>"
  ELEVENLABS_API_KEY: "<YOUR_ELEVENLABS_API_KEY>"

  # ── PagerDuty ──────────────────────────────────────────────────
  PAGERDUTY_ROUTING_KEY: "<YOUR_PAGERDUTY_ROUTING_KEY>"

  # ── App ────────────────────────────────────────────────────────
  SECRET_KEY: "<YOUR_SECRET_KEY_MIN_32_CHARS>"
  DEBUG: "false"
